# Personal photo backend env for Hetzner

# Bind only on localhost and let nginx proxy public traffic.
PERSONAL_PHOTO_SERVER_HOST=127.0.0.1
PERSONAL_PHOTO_SERVER_PORT=8787

# Existing server dataset root. Must contain manifest.json, images/, previews/.
PERSONAL_PHOTO_DATA_DIR=/srv/pastpresentyou/data/timeline-user-data

# External public origin used in generated asset URLs.
PERSONAL_PHOTO_PUBLIC_BASE_URL=https://your-domain.example

# Shared secret for write endpoints.
# Keep this file private.
PERSONAL_PHOTO_WRITE_TOKEN=replace-with-a-long-random-secret
