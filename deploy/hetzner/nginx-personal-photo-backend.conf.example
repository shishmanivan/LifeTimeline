# Example nginx location block for PastPresentYou personal photo backend.
# Put this inside your existing server block.

location /api/personal/ {
    proxy_pass http://127.0.0.1:8787;
    proxy_http_version 1.1;

    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-Host $host;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;

    # Keep the write token on the server side.
    proxy_set_header X-Personal-Write-Token "replace-with-the-same-secret";
}
