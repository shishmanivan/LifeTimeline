# Frontend env for a production-style server-mode build

VITE_PERSONAL_PHOTO_STORAGE=server

# When nginx proxies /api/personal/ on the same host, this is enough.
VITE_PERSONAL_PHOTO_API_BASE_PATH=/api/personal

# Optional only for direct-to-backend local dev.
# Do not use this in a public deployment if nginx can inject the token instead.
# VITE_PERSONAL_PHOTO_WRITE_TOKEN=replace-with-the-same-secret
