{
  "name": "timeline-mvp",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "personal:server": "tsx backend/personalReadonlyServer.ts",
    "personal:server:typecheck": "tsc -p backend/tsconfig.json --noEmit",
    "personal:import": "tsx tools/importPersonalBackupToServerDataset.ts",
    "history:pics": "tsx tools/fetchHistoryPics.ts",
    "history:pics:culture": "tsx tools/fetchHistoryPicsCulture.ts",
    "history:pics:autos": "tsx tools/fetchHistoryPicsAutos.ts",
    "history:pics:tech": "tsx tools/fetchHistoryPicsTech.ts",
    "history:pics:culture:chunk": "tsx tools/fetchHistoryPicsCultureChunk.ts",
    "history:pics:clean": "tsx tools/cleanHistoryPicsDuplicates.ts",
